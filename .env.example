# ============================================================
# Portal BI — Variáveis de Ambiente (Backend / Railway)
# Copie este conteúdo nas variáveis de ambiente do Railway
# ============================================================

# --- Segurança ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-para-uma-chave-secreta-de-64-caracteres-aqui

# --- Banco de dados (Supabase PostgreSQL) ---
# Supabase > Settings > Database > Connection String > URI
# Use a connection string com "Transaction mode" (porta 6543) para Railway
DATABASE_URL=postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# --- Supabase Storage ---
# Supabase > Settings > API > Project URL
SUPABASE_URL=https://xxxx.supabase.co
# Supabase > Settings > API > service_role (secret) — NUNCA exponha no frontend
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Nomes dos buckets (criar no Supabase Storage antes do primeiro deploy)
SUPABASE_BUCKET_COVERS=covers
SUPABASE_BUCKET_PARQUET=parquet

# --- CORS: URL pública do frontend no Railway ---
FRONTEND_URL=https://portal-bi-frontend.up.railway.app
